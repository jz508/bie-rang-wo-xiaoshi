{
  "name": "@bie-rang-wo-xiaoshi/web",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "next dev",
    "build": "npm run build --workspace @bie-rang-wo-xiaoshi/domain && npm run prisma:generate && next build",
    "prisma:generate": "prisma generate --schema ../../prisma/schema.prisma",
    "test": "vitest run",
    "typecheck": "npm run build --workspace @bie-rang-wo-xiaoshi/domain && npm run prisma:generate && tsc --noEmit -p tsconfig.json"
  },
  "dependencies": {
    "@bie-rang-wo-xiaoshi/domain": "0.0.0",
    "@prisma/client": "^6.19.3",
    "next": "^16.1.0",
    "react": "^19.2.7",
    "react-dom": "^19.2.7"
  },
  "devDependencies": {
    "@types/node": "^25.0.3",
    "@types/react": "^19.2.7",
    "@types/react-dom": "^19.2.3",
    "typescript": "^6.0.3",
    "vitest": "^4.1.9"
  }
}
